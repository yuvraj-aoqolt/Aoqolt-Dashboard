{
	"info": {
		"_postman_id": "aoqolt-auth-api-2026",
		"name": "Aoqolt Authentication API",
		"description": "Complete authentication endpoints for Aoqolt Spiritual Services Platform with OTP verification, social login, and password management.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201 || pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.data && response.data.user_id) {",
									"        pm.environment.set(\"user_id\", response.data.user_id);",
									"    }",
									"    if (response.data && response.data.phone_number) {",
									"        pm.environment.set(\"phone_number\", response.data.phone_number);",
									"    }",
									"    if (response.data && response.data.otp_code) {",
									"        pm.environment.set(\"otp_code\", response.data.otp_code);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"full_name\": \"John Doe\",\n    \"email\": \"[email protected]\",\n    \"country_code\": \"+1\",\n    \"phone_number\": \"1234567890\",\n    \"password\": \"SecurePass123!\",\n    \"confirm_password\": \"SecurePass123!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/register/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"register",
								""
							]
						},
						"description": "Register a new user account. Returns OTP for verification. If unverified account exists (same email or phone), allows updating ALL details including email, phone, name, and password before re-sending OTP."
					},
					"response": []
				},
				{
					"name": "Verify OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.data && response.data.tokens) {",
									"        pm.environment.set(\"access_token\", response.data.tokens.access);",
									"        pm.environment.set(\"refresh_token\", response.data.tokens.refresh);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone_number\": \"{{phone_number}}\",\n    \"otp_code\": \"{{otp_code}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/verify-otp/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"verify-otp",
								""
							]
						},
						"description": "Verify OTP and activate account. Returns JWT tokens."
					},
					"response": []
				},
