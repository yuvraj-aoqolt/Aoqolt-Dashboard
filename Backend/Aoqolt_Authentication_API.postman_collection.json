							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"resend-otp",
								""
							]
						},
						"description": "Resend OTP to phone number. Rate limited to 60 seconds."
					},
					"response": []
				},
